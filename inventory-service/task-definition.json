{
  "family": "inventory-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::386689380284:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "inventory",
      "image": "386689380284.dkr.ecr.us-east-1.amazonaws.com/inventory-service:latest",
      "essential": true,
      "portMappings": [
        {
          "name": "inventory",
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/inventory-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
